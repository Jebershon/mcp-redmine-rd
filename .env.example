# Redmine instance
REDMINE_URL=https://redmine.example.com

# --- Auth: choose ONE mode ---

# Mode A — Local single-user (API key). Set REDMINE_API_KEY to your personal key
# from Redmine: My account → API access key. No admin rights needed. When set,
# the server skips OAuth entirely and binds to 127.0.0.1 by default. The MCP
# client must present MCP_LOCAL_TOKEN as a Bearer token.
# REDMINE_API_KEY=your-40-char-api-key
# MCP_LOCAL_TOKEN=local

# Mode B — Centralized OAuth (multi-user). Leave REDMINE_API_KEY unset and provide
# OAuth application credentials (from Redmine: Administration → Applications;
# requires admin rights to register).
REDMINE_CLIENT_ID=your-client-id
REDMINE_CLIENT_SECRET=your-client-secret

# Optional: limit OAuth scopes to what your Redmine app supports (space-separated).
# When set, only the intersection of tool-declared scopes and this list is requested.
# When omitted, all tool-declared scopes are requested automatically.
# REDMINE_SCOPES=view_issues view_project search_project

# FastMCP server
MCP_HOST=0.0.0.0
MCP_PORT=8000
# MCP_BASE_URL=http://localhost:8000  # public-facing URL used for OAuth redirects (defaults to http://localhost:MCP_PORT)

# Optional: how long a verified token is trusted before Redmine is asked again (seconds).
# Every MCP request is verified, so this removes a round-trip per tool call.
# Trade-off: a token revoked in Redmine stays usable here for up to this long. 0 disables caching.
# TOKEN_CACHE_TTL_SECONDS=60

# Optional: comma-separated CORS origins. Defaults to "*" — narrow this for a shared deployment.
# CORS_ALLOW_ORIGINS=https://claude.ai
