# Redmine instance
REDMINE_URL=https://redmine.example.com

# Your personal Redmine API key: My account → API access key. No admin rights needed.
REDMINE_API_KEY=your-40-char-api-key

# --- Optional ---

# Bearer token the MCP client must present in HTTP mode (ignored over stdio).
# MCP_LOCAL_TOKEN=local

# Server bind (HTTP mode). Loopback-only by default.
# MCP_HOST=127.0.0.1
# MCP_PORT=8000

# Comma-separated CORS origins. Defaults to "*" — narrow this for a shared deployment.
# CORS_ALLOW_ORIGINS=https://claude.ai
